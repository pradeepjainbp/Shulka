# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.

# ─── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=
# Pooled connection for application queries (shulka_app role)
DATABASE_URL_POOL=
# Unpooled connection for migrations (shulka_owner role)
DATABASE_URL_UNPOOLED=

# ─── Auth.js ─────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Cloudflare ──────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2 bucket for HSN master + invoice PDFs
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# KV namespace for rate-limiting / session cache
CLOUDFLARE_KV_NAMESPACE_ID=

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@pradeepjainbp.in

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time auth token for source map uploads
SENTRY_AUTH_TOKEN=

# ─── Cloudflare Web Analytics ────────────────────────────────────────────────
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
