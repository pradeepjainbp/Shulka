{
  "name": "shulka",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @shulka/web dev",
    "build": "pnpm --filter @shulka/web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @shulka/web exec tsc --noEmit",
    "db:generate": "pnpm --filter @shulka/db db:generate",
    "db:migrate": "pnpm --filter @shulka/db db:migrate",
    "db:studio": "pnpm --filter @shulka/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.49.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
